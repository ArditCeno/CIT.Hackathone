# Copy this file to .env and fill in your own values.
# Never commit .env — it contains real credentials.

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# If your database name contains spaces, encode them as %20.
# Example with default pgAdmin4 setup on localhost:
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/YOUR_DATABASE_NAME

# Secret key used to sign JWT tokens.
# Change this to any long random string in production.
JWT_SECRET=guardian-hackathon-secret-2026
